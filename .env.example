# Development Environment Variables
# Copy this file to .env and modify as needed

# Database Configuration
SUPABASE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres  # Replace with your Supabase connection string
SUPABASE_URL=your_supabase_url  # Replace with your Supabase project URL
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Replace with your Supabase service role key

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Authentication
BETTER_AUTH_SECRET=your_secret_key_here
BETTER_AUTH_URL=http://localhost:3000

# Address Configuration
NEXT_PUBLIC_ADDRESS_SERVICE_URL=https://www.emsifa.com/api-wilayah-indonesia/api
NEXT_PUBLIC_ADDRESS_INITIAL_VALUE_PROVINCE_ID=18
NEXT_PUBLIC_ADDRESS_INITIAL_VALUE_CITY_ID=1801